{
  "name": "studio-v4",
  "version": "1.0.1",
  "description": "Studio V4 — Editor de vídeo desktop com IA, timeline e integração Google Drive",
  "private": true,
  "main": "electron/main.cjs",
  "author": "Kalyna Lima (V4 Aguiar) & Jamilly Barros (V4 Jasson Oliveira e Co)",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "start": "electron .",
    "pack": "npm run build && electron-builder --win portable nsis",
    "publish": "npm run build && electron-builder --win nsis --publish always",
    "serve-site": "node ../site-server.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "adm-zip": "^0.5.17",
    "archiver": "^6.0.2",
    "electron-updater": "^6.3.9",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "onnxruntime-node": "^1.19.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "lucide-react": "^0.468.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "build": {
    "appId": "com.v4company.studiov4",
    "productName": "Studio V4",
    "copyright": "V4 Aguiar & V4 Jasson Oliveira e Co",
    "asar": true,
    "asarUnpack": [
      "node_modules/onnxruntime-node/**"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/main.cjs",
      "electron/preload.cjs",
      "electron/stems-engine.cjs",
      "dist/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static/ffmpeg.exe",
        "to": "ffmpeg.exe"
      },
      {
        "from": "node_modules/ffprobe-static/bin/win32/x64/ffprobe.exe",
        "to": "ffprobe.exe"
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "v4company",
      "repo": "studio-v4"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Studio V4"
    }
  }
}
